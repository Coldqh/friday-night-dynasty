#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/c/Friday Night Dynasty/friday_night_dynasty_v01/node_modules/.pnpm/vitest@4.1.5_vite@8.0.10/node_modules/vitest/node_modules:/mnt/c/Friday Night Dynasty/friday_night_dynasty_v01/node_modules/.pnpm/vitest@4.1.5_vite@8.0.10/node_modules:/mnt/c/Friday Night Dynasty/friday_night_dynasty_v01/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/c/Friday Night Dynasty/friday_night_dynasty_v01/node_modules/.pnpm/vitest@4.1.5_vite@8.0.10/node_modules/vitest/node_modules:/mnt/c/Friday Night Dynasty/friday_night_dynasty_v01/node_modules/.pnpm/vitest@4.1.5_vite@8.0.10/node_modules:/mnt/c/Friday Night Dynasty/friday_night_dynasty_v01/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../vitest.mjs" "$@"
else
  exec node  "$basedir/../../vitest.mjs" "$@"
fi
